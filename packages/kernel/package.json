    "package": "npm run build && extensions-cli package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "sucrase": "^3.35.0",
    "ws": "^8.18.0",
    "@quantumaudio/music-ir": "^0.1.0",
    "@quantumaudio/ableton-mcp-schemas": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/ws": "^8.5.12",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "license": "Apache-2.0"
}
